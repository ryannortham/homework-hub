# Bitwarden CLI (Vaultwarden) authentication
BW_SERVER=https://vaultwarden.homelab
BW_CLIENTID=user.your-client-id
BW_CLIENTSECRET=your-client-secret
BW_PASSWORD=your-master-password

# Discord webhook for notifications (reuse the existing Notifiarr one)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../slack

# Paths inside the container
HOMEWORK_HUB_CONFIG_DIR=/config
HOMEWORK_HUB_TOKENS_DIR=/config/tokens
HOMEWORK_HUB_STATE_DB=/config/state.db
HOMEWORK_HUB_LOG_DIR=/logs

# Scheduling
HOMEWORK_HUB_SYNC_CRON="7 * * * *"   # hourly at :07
HOMEWORK_HUB_HEALTH_PORT=30062

# Logging
LOG_LEVEL=INFO
TZ=Australia/Melbourne
